{
  "name": "secrets-rotation-manager",
  "version": "2.0.0",
  "description": "Enterprise-grade secrets rotation system with zero-downtime deployment",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "setup": "npm install && node ../scripts/setup.js",
    "seed": "node ../scripts/seed.js",
    "migrate": "node ../scripts/migrate.js"
  },
  "keywords": [
    "secrets",
    "rotation",
    "security",
    "automation",
    "mongodb",
    "express",
    "nodejs",
    "enterprise"
  ],
  "author": "DevOps Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "mongoose": "^9.2.1",
    "node-cron": "^4.2.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.1",
    "supertest": "^6.3.3"
  }
}
