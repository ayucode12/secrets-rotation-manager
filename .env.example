# ===== Database Configuration =====
MONGO_URI=mongodb://localhost:27017/secrets-rotation-manager
MONGODB_USER=admin
MONGODB_PASSWORD=your_secure_password

# ===== Server Configuration =====
NODE_ENV=development
PORT=5000

# ===== Encryption Configuration =====
ENCRYPTION_KEY=your_secure_encryption_key_min_32_chars_long

# ===== Backup Configuration =====
BACKUP_DIR=./backups

# ===== Email Notifications (Optional) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@secrets-manager.local

# ===== Logging Configuration =====
LOG_LEVEL=info
LOG_DIR=./logs

# ===== Service Configuration =====
# Add your dependent services here
DB_SERVICE_ENABLED=true
API_SERVICE_ENABLED=true
CACHE_SERVICE_ENABLED=true

# ===== Rotation Policy Configuration =====
DEFAULT_ROTATION_DURATION_SECONDS=3600
DEFAULT_RETRY_ATTEMPTS=3
DEFAULT_RETRY_DELAY_MS=5000

# ===== Git Configuration =====
GIT_COMMIT_ROTATIONS=true
GIT_REPO_PATH=./rotation-policies

# ===== Security Configuration =====
API_KEY_VALIDATION=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
