# ===== Server Configuration =====
NODE_ENV=development
PORT=5000

# ===== Database Configuration =====
MONGO_URI=mongodb://localhost:27017/secrets-rotation-manager
MONGODB_USER=
MONGODB_PASSWORD=

# ===== Authentication & Security =====
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_256_bits_long_for_production
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
API_KEY_VALIDATION=true

# ===== Encryption Configuration =====
ENCRYPTION_KEY=your_secure_encryption_key_min_32_chars_long_change_in_prod

# ===== CORS Configuration =====
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true

# ===== Rate Limiting =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== Logging Configuration =====
LOG_LEVEL=info
LOG_DIR=./logs

# ===== Backup Configuration =====
BACKUP_DIR=./backups

# ===== Email Notifications =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@secrets-manager.local

# ===== Rotation Policy Configuration =====
DEFAULT_ROTATION_DURATION_SECONDS=3600
DEFAULT_RETRY_ATTEMPTS=3
DEFAULT_RETRY_DELAY_MS=5000

# ===== Service Configuration =====
DB_SERVICE_ENABLED=true
API_SERVICE_ENABLED=true
CACHE_SERVICE_ENABLED=true

# ===== Git Configuration =====
GIT_COMMIT_ROTATIONS=true
GIT_REPO_PATH=./rotation-policies

# ===== Session Configuration =====
SESSION_SECRET=your_session_secret_key_change_in_production
SESSION_MAX_AGE=86400000

# ===== Redis Configuration (for production caching) =====
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ===== Monitoring =====
PROMETHEUS_ENABLED=false
METRICS_PORT=9090

