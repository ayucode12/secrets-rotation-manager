# Git Ignore for Secrets Rotation Manager

# Environment variables
.env
.env.local
.env.*.local

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backups and temporary files
backups/
*.backup
*.tmp
temp/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build and dist
dist/
build/
.next/

# Test coverage
coverage/
.nyc_output/

# Rotation policies (Git tracks these separately)
rotation-policies/
!rotation-policies/.gitkeep

# OS files
Thumbs.db
.DS_Store
*.exe

# Secrets and sensitive data
*.pem
*.key
*.crt
secrets.json
credentials.json

# Database files
*.db
*.sqlite

# Runtime
.env.production
pids/
*.pid
